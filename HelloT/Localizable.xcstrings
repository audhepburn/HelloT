    "desc.flat": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einfaches Listenlayout ohne Schatten, mit farbigen Blöcken und Linien als visuelle Elemente."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clean list-based layout without shadows, using color blocks and lines as visual elements."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用简洁的列表式布局，去除阴影和圆形按钮，以纯色色块和线条为主要视觉元素。"
          }
        }
      }
    },
    "desc.neumorphism": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Neumorphismus-Stil erzeugt durch doppelte Schatten ein erhobenes und vertieftes Erscheinungsbild mit weicher, dreidimensionaler Wirkung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Neumorphism style uses dual shadows to create raised and inset textures with a soft, three-dimensional feel."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新拟态（Neumorphism）风格，通过双层阴影营造凸起与凹陷的质感，柔和而富有立体感。"
          }
        }
      }
    },
